# Copy to .env and fill in your values

# Porcupine wake word
PORCUPINE_ACCESS_KEY=your_key
WAKE_WORD_ENABLED=true
WAKE_WORD_KEYWORD_PATHS=assets/wake_word.ppn

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:0.5b
# Short voice replies
OLLAMA_NUM_PREDICT=56
# Full Google Docs bodies (raise if essays still truncate)
OLLAMA_NUM_PREDICT_GOOGLE=4096
OLLAMA_TIMEOUT_GOOGLE=180
OLLAMA_NUM_PREDICT_GMAIL=96
GMAIL_UNREAD_MAX=6
# Calendar: set your zone so "tomorrow at 8am" is correct (optional; empty = OS local)
# LOCAL_TIMEZONE=Asia/Kolkata

# Listening — longer pause before "no speech" (ms) and max clip length (s)
SILENCE_END_MS=1000
RECORD_SECONDS=30

# Speed
USE_FASTER_WHISPER=true
PLAYBACK_METHOD=subprocess

# Google addon (credentials file is core/credentials.json — see CREDENTIALS.md)
GOOGLE_PREWARM=true
WARNING_DAEMON_ENABLED=true
